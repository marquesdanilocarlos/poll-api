{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "moduleResolution": "Node",
    "types": ["vitest/globals"]
  },
  "include": ["src"],
  "exclude": ["eslint.config.js"]
}
